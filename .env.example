# ─── Mio Configuration ──────────────────────────────────────────────────────
# Copy to .env and fill in your settings:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ─── AI Provider ────────────────────────────────────────────────────────────
# Set ONE API key. Auto-detected when MIO_PROVIDER=auto.
# Presets: anthropic, openai, deepseek, moonshot, zhipu, minimax, qwen,
#          doubao, siliconflow

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/
OPENAI_API_KEY=

# DeepSeek（深度求索）— https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Moonshot / Kimi（月之暗面）— https://platform.moonshot.cn/
MOONSHOT_API_KEY=

# Zhipu / GLM（智谱清言）— https://open.bigmodel.cn/
ZHIPU_API_KEY=

# MiniMax（稀宇科技）— https://www.minimax.com/
MINIMAX_API_KEY=

# Qwen / 通义千问（阿里云）— https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# Doubao / 豆包（字节跳动）— https://console.volcengine.com/ark/
DOUBAO_API_KEY=

# SiliconFlow（硅基流动）— https://siliconflow.cn/
SILICONFLOW_API_KEY=

MIO_PROVIDER=auto
# MIO_PROVIDER_BASE_URL=   # Custom API base URL (overrides preset)

# Model override — uses provider default if empty
# COLA_MODEL=

# ─── Model Router ───────────────────────────────────────────────────────────
# MIO_MODEL_CHAT=             # Model for chat turns
# MIO_MODEL_CLASSIFY=         # Model for intent classification
# MIO_MODEL_SUMMARIZE=        # Model for summarization
# MIO_MODEL_REFLECT=          # Model for memory reflection
# MIO_MODEL_EMBED=            # Model for embeddings
# MIO_MODEL_ROUTER_ENABLED=   # Enable per-task model routing
# MIO_FALLBACK_CHAIN=         # Comma-separated provider fallback order

# ─── Feature Flags ──────────────────────────────────────────────────────────
# Set to "false" to disable. All default to true (enabled).

# MIO_FEATURE_GHOST=true               # Ghost silence mechanism
# MIO_FEATURE_AFFINITY=true             # 5-axis affinity
# MIO_FEATURE_MULTI_AXIS_RELATIONSHIP=true  # Multi-axis relationship
# MIO_FEATURE_FRUSTRATION=true          # Frustration streak tracking
# MIO_FEATURE_ACE_REFLECTOR=true        # Memory quality reflection
# MIO_FEATURE_MODEL_ROUTER=false        # Per-task model routing
# MIO_FEATURE_BUDGET_LOG=false          # Log prompt token budgets
# MIO_FEATURE_SMART_PROACTIVE=true      # Poisson-based proactive
# MIO_FEATURE_TELEGRAM_NOTIFY=auto      # Telegram notifications
# MIO_FEATURE_XML_CONTEXT=true          # XML-formatted context blocks
# MIO_FEATURE_POST_HISTORY=true         # Post-history injection
# MIO_FEATURE_LOREBOOK=true             # Lorebook generation
# MIO_FEATURE_3_PHASE_CONSOLIDATION=true # 3-phase nightly consolidation
# MIO_FEATURE_PROCEDURAL_MEMORY=true    # Procedural memory extraction
# MIO_FEATURE_TRAIT_STATE=true          # OCEAN trait state separation
# MIO_FEATURE_ADAPTIVE_HISTORY=true     # Adaptive history window
# MIO_FEATURE_LLM_JUDGE=true            # LLM consistency judge
# MIO_FEATURE_EXPERIENCE_TRAIT=true     # Experience → trait feedback
# MIO_FEATURE_ENTITY_GRAPH=true         # Entity relationship graph
# MIO_FEATURE_DYNAMIC_FEWSHOT=true      # Dynamic few-shot selection
# MIO_PAD_ENABLED=true                  # PAD 3D emotional model

# ─── Server ─────────────────────────────────────────────────────────────────
# MIO_HTTP_PORT=0               # Listen port (0 = auto)
# MIO_HTTP_HOST=127.0.0.1       # Bind host; use 0.0.0.0 behind Docker/reverse proxy
# MIO_AUTH_TOKEN=               # Bearer token for API auth (empty = no auth)
# MIO_CORS_ORIGIN=              # Comma-separated allowed browser origins or * for public API clients
# MIO_RATE_LIMIT_MAX=30         # Max requests per window per IP
# MIO_RATE_LIMIT_WINDOW_MS=60000 # Rate limit window in ms

# ─── IM Bridge ──────────────────────────────────────────────────────────────
# MIO_OPENAI_REQUIRE_SESSION=false # Require stable session id on /v1/chat/completions; recommended for WeChat/QQ gateways
# MIO_WECLAW_API_ADDR=127.0.0.1:18011 # WeClaw local send/status API
# MIO_WECLAW_BIN=~/.local/bin/weclaw-mio-session # Patched WeClaw binary that forwards conversationID
# MIO_WECLAW_NOTIFY=false      # Global safety switch for proactive outbound sends through WeClaw
# MIO_WECLAW_TO=               # Legacy/manual-test fallback only; proactive uses per-user channels.weclaw.to
# MIO_ONEBOT_API_BASE=          # OneBot HTTP API base, e.g. http://127.0.0.1:3001
# MIO_ONEBOT_ACCESS_TOKEN=      # Bearer token for outbound OneBot API calls
# MIO_ONEBOT_REPLY_MODE=        # api | quick | both | off
# MIO_ONEBOT_GROUP_MODE=mention # mention | all | off
# MIO_ONEBOT_TIMEOUT_MS=10000   # Outbound OneBot API timeout

# ─── Scheduler ──────────────────────────────────────────────────────────────
# MIO_NIGHTLY_CRON=30 21 * * *  # Cron expression for nightly pipeline
# MIO_NIGHTLY_ENABLED=true      # Enable nightly consolidation

# ─── Notifications ──────────────────────────────────────────────────────────
# MIO_TELEGRAM_BOT_TOKEN=       # Telegram bot token
# MIO_TELEGRAM_CHAT_ID=         # Telegram target chat ID
# MIO_WEBHOOK_URL=              # Generic webhook URL
# MIO_WHATSAPP_TOKEN=           # WhatsApp Cloud API token
# MIO_WHATSAPP_PHONE_ID=        # WhatsApp phone number ID
# MIO_WHATSAPP_TO=              # WhatsApp recipient number
# MIO_DISCORD_TOKEN=            # Discord bot token
# MIO_DISCORD_CHANNEL_ID=       # Discord channel ID
# MIO_SLACK_WEBHOOK_URL=        # Slack incoming webhook URL

# ─── Voice ──────────────────────────────────────────────────────────────────
# MIO_MIC_DEVICE=               # Microphone device name
# MIO_WHISPER_MODEL=whisper-1   # Whisper model
# MIO_WHISPER_LANG=zh           # Transcription language

# ─── Data & Logging ─────────────────────────────────────────────────────────
# MIO_DIR=                      # Data directory (default: ./data)
# MIO_LOG_LEVEL=info            # debug | info | warn | error
# MIO_LOG_FORMAT=text           # text | json
# MIO_LOG_FILE=                 # Log file path (default: stdout only)

# ─── Embedding ──────────────────────────────────────────────────────────────
# MINIMAX_DISABLE=false         # Disable MiniMax embeddings (use TF fallback)
