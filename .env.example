# ─── Mio Configuration ───
# Copy this file to .env and fill in your settings.
#   cp .env.example .env

# ─── AI Provider ───
# Set ONE of these API keys. Use with MIO_PROVIDER=auto for auto-detect,
# or set MIO_PROVIDER to a specific preset name.
#
# Available presets: anthropic, openai, deepseek, moonshot, zhipu,
#                     minimax, qwen, doubao, siliconflow

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# DeepSeek（深度求索）— https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Moonshot / Kimi（月之暗面）— https://platform.moonshot.cn/
MOONSHOT_API_KEY=

# Zhipu / GLM（智谱清言）— https://open.bigmodel.cn/
ZHIPU_API_KEY=

# MiniMax（稀宇科技）— https://www.minimax.com/
MINIMAX_API_KEY=

# Qwen / 通义千问（阿里云）— https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# Doubao / 豆包（字节跳动）— https://console.volcengine.com/ark/
DOUBAO_API_KEY=

# SiliconFlow（硅基流动）— https://siliconflow.cn/
SILICONFLOW_API_KEY=

# OpenAI — https://platform.openai.com/
OPENAI_API_KEY=

# Provider selection (default: auto — detects from available keys above)
MIO_PROVIDER=auto

# Model override (uses provider default if empty)
COLA_MODEL=

# ─── Server ───
MIO_HTTP_PORT=3000

# Auth token (optional — if set, all POST/WS requests need "Authorization: Bearer <token>")
MIO_AUTH_TOKEN=

# ─── Voice (optional) ───
# Whisper transcription (same key as OpenAI)
# OPENAI_API_KEY=  (set above)

# ─── Scheduler ───
MIO_NIGHTLY_CRON=30 21 * * *
MIO_NIGHTLY_ENABLED=true

# ─── Data ───
# Custom data directory (default: ./data)
MIO_DIR=

# ─── Embedding ───
# MiniMax embeddings (optional — uses TF fallback otherwise)
MINIMAX_API_KEY=
MINIMAX_DISABLE=false
