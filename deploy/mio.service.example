[Unit]
Description=Mio companion agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/mio
EnvironmentFile=/etc/mio/mio.env
ExecStart=/usr/bin/node /opt/mio/dist/index.js serve --host ${MIO_HTTP_HOST} --port ${MIO_HTTP_PORT}
Restart=on-failure
RestartSec=5
TimeoutStopSec=30

# Basic hardening. If your MIO_DIR is outside /opt/mio or /var/lib/mio,
# update ReadWritePaths accordingly.
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/mio /var/lib/mio

[Install]
WantedBy=multi-user.target
