{
  "name": "@mio/idrag",
  "version": "0.6.0",
  "description": "ID-RAG knowledge graph — bootstrap a persona from markdown, retrieve contextually relevant subgraphs at inference time",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./graph": {
      "types": "./dist/graph.d.ts",
      "import": "./dist/graph.js"
    },
    "./extractor": {
      "types": "./dist/extractor.d.ts",
      "import": "./dist/extractor.js"
    },
    "./generator": {
      "types": "./dist/generator.d.ts",
      "import": "./dist/generator.js"
    },
    "./driver": {
      "types": "./dist/driver.d.ts",
      "import": "./dist/driver.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "npm run build -w @mio/emotion && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@mio/emotion": "*"
  },
  "license": "MIT"
}
